# 前端环境变量示例。复制为 .env 后按本地后端地址修改。
# API 基础地址（后端 origin）。/api 前缀由 frontend/src/api/client.ts 统一拼接。
VITE_API_BASE_URL=http://localhost:8080
# WebSocket 基础地址；本地 dev 若不配置，代码会回退到同源 /ws。
VITE_WS_BASE_URL=ws://localhost:8080/ws
# 学生端入口基础地址（生成二维码 / joinUrl 时使用）。
VITE_STUDENT_BASE_URL=http://localhost:5173/student
