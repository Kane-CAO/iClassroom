# iClassroom backend — environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env` (it is gitignored).

# ===== Application =====
# development | production
APP_ENV=development
# HTTP listen port (no colon)
SERVER_PORT=8080

# ===== MySQL =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=iclassroom

# ===== MySQL connection pool =====
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME_MINUTES=5

# ===== CORS =====
# Comma-separated list of allowed frontend origins (dev defaults to Vite).
CORS_ALLOWED_ORIGINS=http://localhost:5173
